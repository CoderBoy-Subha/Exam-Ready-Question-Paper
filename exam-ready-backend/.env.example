NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Number of reverse-proxy hops in front of this server (nginx/ALB/etc).
# Used for `app.set('trust proxy', ...)` so req.ip reflects the real
# client IP rather than the proxy's. Set to 0 if there's no proxy.
TRUST_PROXY_HOPS=1

DATABASE_URL=postgresql://user:password@localhost:5432/examgen
REDIS_URL=redis://localhost:6379

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key-here
# Verify the current recommended model at
# https://ai.google.dev/gemini-api/docs/models before deploying —
# this changes often. gemini-3-flash-preview is current guidance as
# of this writing; gemini-3.5-flash also appears in current docs.
GEMINI_MODEL=gemini-3-flash-preview

# --- Cloudflare Turnstile (bot check on /generations) ---
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here
# Set to "true" to skip verification in local dev without a real key
TURNSTILE_DISABLED=false

# --- Session / retention ---
SESSION_TTL_MINUTES=45
PURGE_SWEEP_INTERVAL_MINUTES=5

# --- Abuse protection ---
RATE_LIMIT_MAX_GENERATIONS_PER_HOUR=10
UPLOAD_MAX_FILE_SIZE_MB=15
UPLOAD_MAX_FILES=6
